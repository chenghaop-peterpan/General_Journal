# Copy to .env.local for local dev. DO NOT commit .env.local.
# Apps Script Web App /exec URL (from Apps Script "Deploy > New deployment")
VITE_API_URL=https://script.google.com/macros/s/XXXXX/exec

# Google Identity Services OAuth 2.0 Client ID (Web application, from Google Cloud Console)
VITE_GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxx.apps.googleusercontent.com

# Only set at build time for GitHub Pages: '/<repo-name>/'. Leave unset locally.
# VITE_BASE=/fund-app/
